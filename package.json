{
  "name": "novaryn",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently --names api,ui --prefix-colors cyan,magenta \"bun run --watch src/server.ts\" \"bun --cwd frontend dev\"",
    "dev:api": "bun run --watch src/server.ts",
    "dev:ui": "bun --cwd frontend dev",
    "start": "bun run src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run scripts/seed.ts",
    "bundle:api": "bun run scripts/bundle-api.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  }
}
