{
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api/auth/:path*" },
    { "source": "/admin/:path*", "destination": "/api/admin/:path*" },
    { "source": "/services/:path*", "destination": "/api/services/:path*" },
    { "source": "/tools/:path*", "destination": "/api/tools/:path*" },
    { "source": "/evaluate", "destination": "/api/evaluate" },
    { "source": "/stream", "destination": "/api/stream" },
    { "source": "/health", "destination": "/api/health" },
    { "source": "/((?!api/|assets/|favicon.ico|vite.svg).*)", "destination": "/index.html" }
  ]
}
