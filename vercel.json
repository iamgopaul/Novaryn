{
  "installCommand": "bun install && cd frontend && bun install",
  "buildCommand": "cd frontend && bun run build && cd .. && rm -rf dist && cp -R frontend/dist dist",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api/auth/:path*" },
    { "source": "/admin/:path*", "destination": "/api/admin/:path*" },
    { "source": "/evaluate", "destination": "/api/evaluate" },
    { "source": "/stream", "destination": "/api/stream" },
    { "source": "/health", "destination": "/api/health" },
    { "source": "/invite/:path*", "destination": "/index.html" },
    { "source": "/reset-password/:path*", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/register", "destination": "/index.html" },
    { "source": "/flags", "destination": "/index.html" },
    { "source": "/experiments", "destination": "/index.html" },
    { "source": "/audit", "destination": "/index.html" },
    { "source": "/keys", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" }
  ]
}
